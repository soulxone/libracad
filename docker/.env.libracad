# LibraCAD Docker Environment
# Copy this to your frappe_docker/.env or merge with existing .env

ERPNEXT_VERSION=v15.36.0
CUSTOM_IMAGE=custom-erpnext
CUSTOM_TAG=libracad
PULL_POLICY=never

DB_PASSWORD=123
FRAPPE_SITE_NAME_HEADER=localhost

# For volume-mount development (Option B)
LIBRACAD_APP_PATH=D:/Maps in Frappe App/libracad/libracad
